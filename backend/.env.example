# Banco de dados
DB_URL=jdbc:postgresql://localhost:5432/studentdb
DB_NAME=studentdb
DB_USER=postgres
DB_PASSWORD=changeme

# PgAdmin (opcional, apenas para docker-compose local)
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# JWT
API_SECURITY_TOKEN_SECRET=changeme-please-generate-a-strong-secret

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Mercado Pago
# Access Token de produção começa com APP_USR-...  / de testes com TEST-...
# Obtenha em: https://www.mercadopago.com.br/developers/panel
MERCADOPAGO_ACCESS_TOKEN=TEST-replace-with-your-token
# Secret para validar a assinatura HMAC dos webhooks (configurado no painel do MP)
MERCADOPAGO_WEBHOOK_SECRET=replace-with-your-webhook-secret
# Em dev, exponha localhost via ngrok e use a URL pública aqui
MERCADOPAGO_NOTIFICATION_URL=http://localhost:8080/api/payments/webhook/mercadopago
MERCADOPAGO_API_BASE_URL=https://api.mercadopago.com
